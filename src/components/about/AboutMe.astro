---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import authorImage from "@/assets/images/about/designer.jpg";

interface AboutItem {
  title: string;
  description: string;
  icon: string;
}

const aboutItems: AboutItem[] = [
  {
    title: "검색과 AI 모두에서 추천하는 홈페이지",
    description: "구글 검색엔진 최적화(SEO)는 기본. ChatGPT, Perplexity가 답변할 때 당신의 비즈니스를 인용하도록 구조를 설계합니다",
    icon: "tabler/north-star",
  },
  {
    title: "콘텐츠 자동화 시스템",
    description: "블로그 주 1회 발행이 주 5회로. 키워드만 입력하면 SEO 최적화된 글이 자동 생성되고, 검수 후 원클릭으로 발행됩니다",
    icon: "tabler/bulb",
  },
  {
    title: "마케팅 자동화 시스템",
    description: "운영 리소스 70% 절감, 전환율 1.8배 상승. 문의 접수부터 CRM 등록, 후속 이메일, SNS 공유까지 전부 자동입니다",
    icon: "tabler/bolt",
  },
];
---

<section id="about-alt" class="bg-background text-foreground overflow-hidden py-16 md:py-24">
  <div class="site-container">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
        <div class="order-2 lg:order-1">
          <div data-mos="fade-right" data-mos-anchor="#about-alt">
            <h2 class="text-foreground h2 mb-4">홈페이지가 일하게 만드세요</h2>
            <p class="description mb-4">
              10년 전, 일본 이메일 마케팅 SaaS 한국 지사 대표로서 감과 수동 작업에 의존한 마케팅의 한계를 뼈저리게 경험했습니다. 이후 한·일·미 마케팅 전략을 밑바닥부터 다시 공부하고, 수백 번의 A/B 테스트와 자동화 워크플로우를 직접 구축하며 시스템 아키텍트로 진화했습니다.
            </p>
            <p class="description mb-4">
              그 결과, 3년 만에 한 기업의 매출을 <strong>90억에서 300억으로</strong> 성장시켰습니다. 운이 아니라, 마케팅의 모든 단계에 지능형 시스템을 설계한 결과입니다.
            </p>
            <p class="description mb-12">
              이제 Thales Web은 그 경험을 바탕으로, 구글이 신뢰하고 ChatGPT가 인용하며 고객 문의까지 자동으로 처리되는 — 알아서 영업하는 시스템을 설계합니다.
            </p>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {
              aboutItems.map((item, idx) => (
                <div
                  class="group hover:bg-muted rounded-lg border p-6 shadow-md transition-colors"
                  data-mos="fade-in"
                  data-mos-anchor="#about-alt"
                  data-mos-delay={0.8 + idx * 0.2}
                >
                  <Icon name={item.icon} class="text-primary-accent h-8 w-8" />
                  <h3 class="text-foreground group-hover:text-primary-accent mt-2 mb-2 text-lg font-semibold transition-colors duration-300">
                    {item.title}
                  </h3>
                  <p class="text-muted-foreground text-sm">{item.description}</p>
                </div>
              ))
            }
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="relative" data-mos="fade-left" data-mos-anchor="#about-alt">
            <div class="relative">
              <Image
                src={authorImage}
                alt="Designer"
                class="aspect-square w-full rounded-xl object-cover shadow-md md:rounded-2xl"
              />
            </div>
            <div class="bg-primary/10 absolute -right-4 -bottom-4 h-32 w-32 rounded-full blur-2xl">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
