---
/**
 * * FAQ section in accordions
 * Auto-generates FAQPage JSON-LD schema (AEO)
 */

import { clientConfig } from "@/config/clientConfig";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { generateFaqPageSchema } from "@/js/jsonLD";
import { getTranslatedData } from "@/js/translationUtils";

import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from "./faq-accordion-standard";

const currLocale = getLocaleFromUrl(Astro.url);
const faqData = getTranslatedData("faqData", currLocale);

const faqSchema = clientConfig.seo.enableFaqSchema
  ? generateFaqPageSchema(faqData)
  : null;
---

<section id="faq-accordions" class="py-16 md:py-24">
  <div class="site-container">
    <div class="mx-auto mb-16 max-w-3xl text-center" data-mos="fade-up">
      <h2 class="h2 mb-4">Frequently Asked Questions</h2>
      <p class="description">Find answers to common questions about our services and process</p>
    </div>
    <div
      class="mx-auto mt-10 flex max-w-3xl flex-col gap-3"
      data-mos="fade-up"
      data-mos-delay="0.4"
    >
      <Accordion class="space-y-3">
        {
          faqData.map((faqItem, idx) => (
            <AccordionItem value={`item-${idx}`}>
              <AccordionTrigger>{faqItem.question}</AccordionTrigger>
              <AccordionContent class="markdown-content" details={faqItem.answer} />
            </AccordionItem>
          ))
        }
      </Accordion>
    </div>
  </div>

  {faqSchema && (
    <Fragment
      set:html={`<script type="application/ld+json">${JSON.stringify(faqSchema)}</script>`}
    />
  )}
</section>
