---
/**
 * Core Web Vitals Tracking Component
 * Measures CLS, LCP, INP and sends to GA4 as custom events.
 * Only active when Google Analytics is configured.
 */
import { clientConfig } from "@/config/clientConfig";

const gaId = clientConfig.analytics.googleAnalyticsId;
---

{
  gaId && (
    <script is:inline>
      // Lightweight Core Web Vitals reporter
      // Sends CLS, LCP, INP metrics to GA4
      (function () {
        function sendToGA4(name, value, rating) {
          if (typeof gtag !== "function") return;
          gtag("event", name, {
            value: Math.round(name === "CLS" ? value * 1000 : value),
            event_category: "Web Vitals",
            event_label: rating,
            non_interaction: true,
          });
        }

        // CLS (Cumulative Layout Shift)
        var clsValue = 0;
        new PerformanceObserver(function (list) {
          for (var entry of list.getEntries()) {
            if (!entry.hadRecentInput) {
              clsValue += entry.value;
            }
          }
        }).observe({ type: "layout-shift", buffered: true });

        // LCP (Largest Contentful Paint)
        new PerformanceObserver(function (list) {
          var entries = list.getEntries();
          var lastEntry = entries[entries.length - 1];
          var value = lastEntry.startTime;
          var rating = value <= 2500 ? "good" : value <= 4000 ? "needs-improvement" : "poor";
          sendToGA4("LCP", value, rating);
        }).observe({ type: "largest-contentful-paint", buffered: true });

        // Send CLS on page hide
        document.addEventListener("visibilitychange", function () {
          if (document.visibilityState === "hidden") {
            var rating =
              clsValue <= 0.1 ? "good" : clsValue <= 0.25 ? "needs-improvement" : "poor";
            sendToGA4("CLS", clsValue, rating);
          }
        });

        // INP (Interaction to Next Paint)
        var inpValue = 0;
        new PerformanceObserver(function (list) {
          for (var entry of list.getEntries()) {
            if (entry.duration > inpValue) {
              inpValue = entry.duration;
            }
          }
        }).observe({ type: "event", buffered: true });

        document.addEventListener("visibilitychange", function () {
          if (document.visibilityState === "hidden" && inpValue > 0) {
            var rating =
              inpValue <= 200 ? "good" : inpValue <= 500 ? "needs-improvement" : "poor";
            sendToGA4("INP", inpValue, rating);
          }
        });
      })();
    </script>
  )
}
