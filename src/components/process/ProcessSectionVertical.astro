---
import { Image } from "astro:assets";

import VerticalProcessStep from "./ProcessStepVertical.astro";

interface VerticalProcessStepProps {
  title: string;
  description: string;
  icon: string;
}

const verticalProcessSteps: VerticalProcessStepProps[] = [
  {
    title: "무료 상담",
    description:
      "30분이면 충분합니다. 현재 상황을 듣고, 어떤 시스템이 가장 효과적일지 함께 정리합니다.",
    icon: "tabler/message-dots",
  },
  {
    title: "SEO/GEO 진단",
    description:
      "현재 웹사이트의 검색 점수와 경쟁사 대비 위치를 진단합니다. 숫자로 보여드리니 판단이 쉬워집니다.",
    icon: "tabler/clipboard",
  },
  {
    title: "시스템 구축",
    description:
      "최적화된 홈페이지와 자동화 워크플로우를 한 번에 구축합니다. 평균 4~6주면 완성됩니다.",
    icon: "tabler/code",
  },
  {
    title: "테스트 & 검증",
    description:
      "자동화도 100번 이상 테스트 후 런칭합니다.",
    icon: "tabler/circle-check",
  },
  {
    title: "런칭 & 성장",
    description:
      "런칭 후 끝이 아닙니다. 성과 데이터를 함께 보며 지속적으로 개선합니다. 운영 교육도 포함됩니다.",
    icon: "tabler/bolt",
  },
];

import designImg from "@/assets/images/design-img-2-min.jpg";
---

<section class="bg-background text-foreground py-16 md:py-24">
  <div class="site-container mx-auto px-4">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <div>
        <div class="max-w-2xl">
          <h2 class="h2 mb-4">AI-MSB 프로세스</h2>
          <p class="description mb-16">AI Marketing System Building — 상담부터 런칭까지, 검증된 5단계</p>

          <div id="process-vertical" class="relative space-y-12">
            <!-- Vertical Line -->
            <div
              class="from-primary/30 to-primary/5 absolute top-0 bottom-0 left-8 w-px bg-gradient-to-b"
            >
            </div>

            {
              verticalProcessSteps.map((step, index) => (
                <VerticalProcessStep
                  number={index + 1}
                  title={step.title}
                  description={step.description}
                  icon={step.icon}
                  data-mos="fade-up"
                  data-mos-delay={index * 0.2}
                  data-mos-anchor="#process-vertical"
                />
              ))
            }
          </div>
        </div>
      </div>

      <!-- Image Section -->
      <div class="relative hidden lg:block">
        <div
          class="group relative aspect-[3/4] overflow-hidden rounded-xl border"
          data-mos="fade-up"
          data-mos-delay=".2"
          data-mos-anchor="#process-vertical"
        >
          <Image
            src={designImg}
            width={600}
            densities={[1, 2]}
            alt="Design process illustration"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
