---
import { Image } from "astro:assets";

import VerticalProcessStep from "./ProcessStepVertical.astro";

interface VerticalProcessStepProps {
  title: string;
  description: string;
  icon: string;
}

const verticalProcessSteps: VerticalProcessStepProps[] = [
  {
    title: "무료 상담",
    description:
      "비즈니스 목표, 현재 마케팅 현황, 타겟 고객을 파악합니다. 어떤 시스템이 필요한지 함께 정의합니다.",
    icon: "tabler/message-dots",
  },
  {
    title: "진단 & 전략 수립",
    description:
      "현재 웹사이트의 SEO/GEO 점수를 진단하고, 경쟁사 분석을 통해 맞춤 최적화 전략과 자동화 설계안을 제안합니다.",
    icon: "tabler/clipboard",
  },
  {
    title: "시스템 구축",
    description:
      "SEO/GEO/AEO 최적화 웹사이트 구축, 콘텐츠 자동화 파이프라인 설정, 마케팅 자동화 워크플로우를 구현합니다.",
    icon: "tabler/code",
  },
  {
    title: "테스트 & 최적화",
    description:
      "구축된 시스템의 성능을 검증하고, AI 검색 인용 테스트, 자동화 워크플로우 안정성을 확인합니다.",
    icon: "tabler/circle-check",
  },
  {
    title: "런칭 & 지속 관리",
    description:
      "시스템을 런칭하고, 성과 데이터를 모니터링하며 지속적으로 최적화합니다. 운영 교육도 제공합니다.",
    icon: "tabler/bolt",
  },
];

import designImg from "@/assets/images/design-img-2-min.jpg";
---

<section class="bg-background text-foreground py-16 md:py-24">
  <div class="site-container mx-auto px-4">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <div>
        <div class="max-w-2xl">
          <h2 class="h2 mb-4">진행 프로세스</h2>
          <p class="description mb-16">상담부터 런칭까지, 체계적인 5단계 프로세스</p>

          <div id="process-vertical" class="relative space-y-12">
            <!-- Vertical Line -->
            <div
              class="from-primary/30 to-primary/5 absolute top-0 bottom-0 left-8 w-px bg-gradient-to-b"
            >
            </div>

            {
              verticalProcessSteps.map((step, index) => (
                <VerticalProcessStep
                  number={index + 1}
                  title={step.title}
                  description={step.description}
                  icon={step.icon}
                  data-mos="fade-up"
                  data-mos-delay={index * 0.2}
                  data-mos-anchor="#process-vertical"
                />
              ))
            }
          </div>
        </div>
      </div>

      <!-- Image Section -->
      <div class="relative hidden lg:block">
        <div
          class="group relative aspect-[3/4] overflow-hidden rounded-xl border"
          data-mos="fade-up"
          data-mos-delay=".2"
          data-mos-anchor="#process-vertical"
        >
          <Image
            src={designImg}
            width={600}
            densities={[1, 2]}
            alt="Design process illustration"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
