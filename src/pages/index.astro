---
import AboutMe from "@/components/about/AboutMe.astro";
import BlogSectionGrid from "@/components/blog/BlogSectionGrid.astro";
import Contact from "@/components/contact/Contact.astro";
import FaqAccordions from "@/components/faq/FaqAccordions.astro";
import HeroCentered from "@/components/hero/HeroCentered.astro";
import LogoCloudMarquee from "@/components/logo-cloud/LogoCloudMarquee.astro";
import PricingOnePrice from "@/components/pricing/PricingOnePrice.astro";
import ProcessSectionVertical from "@/components/process/ProcessSectionVertical.astro";
import ProjectShowcaseSideImage from "@/components/project-showcase/ProjectShowcaseSideImage.astro";
import TestimonialSwiper from "@/components/testimonials/TestimonialSwiper.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getTranslatedData } from "@/js/translationUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title={siteData.title} description={siteData.description} navStyle="dark">
  <HeroCentered />
  <LogoCloudMarquee />
  <AboutMe />
  <ProjectShowcaseSideImage />
  <ProcessSectionVertical />
  <PricingOnePrice />
  <TestimonialSwiper />
  <BlogSectionGrid />
  <Contact />
  <FaqAccordions expandAll />
</BaseLayout>
