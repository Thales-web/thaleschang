---
import Contact from "@/components/contact/Contact.astro";
import FaqAccordions from "@/components/faq/FaqAccordions.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { useTranslations } from "@/js/translationUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
---

<BaseLayout title="문의하기 - SEO/GEO/AEO 최적화 홈페이지 무료 진단" description="Astro 기반 SEO/GEO/AEO 최적화 홈페이지 제작, 마케팅 자동화 시스템 구축에 대한 무료 상담을 신청하세요. 대표가 직접 검토 후 진단 리포트를 보내드립니다.">
  <div class="mt-16">
    <Contact />
  </div>
  <FaqAccordions expandAll />
</BaseLayout>
