---
import { type Page } from "astro";

import CategoryCloud from "@/components/category-cloud/CategoryCloud.astro";
import Pagination from "@/components/pagination/Pagination.astro";
import PostCard from "@/components/post-card/PostCardMultiLink.astro";
import { getAllPosts } from "@/js/blogUtils";
import { getPageLocale } from "@/js/localeUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths({ paginate }) {
  const posts = await getAllPosts(getPageLocale(import.meta.url));

  return paginate(posts, {
    pageSize: 4,
  });
}

const { page } = Astro.props as { page: Page };
---

<BaseLayout
  title="블로그 - AI 마케팅, SEO, GEO, AEO 전략 가이드"
  description="AI 마케팅 시스템, SEO/GEO/AEO 최적화, 마케팅 자동화에 관한 실전 가이드와 인사이트를 공유합니다."
  prevUrl={page.url.prev}
  nextUrl={page.url.next}
>
  <section class="site-container py-24 md:pt-40">
    <div class="overflow-x-clip">
      <div class="mr-auto flex max-w-5xl flex-col">
        <h1 class="h1">AI 마케팅 & 검색 최적화 블로그</h1>
        <p class="text-muted-foreground mt-2 md:text-lg">
          AI 마케팅 시스템, SEO/GEO/AEO 최적화, 마케팅 자동화에 관한 실전 가이드와 인사이트
        </p>
      </div>

      <div class="mt-6 flex pb-16">
        <CategoryCloud />
      </div>
    </div>

    <div class="grid gap-8 gap-y-10 md:grid-cols-2">
      {page.data.map((post) => <PostCard post={post} showDescription={true} data-mos="fade-up" />)}
    </div>

    <div class="mt-10 flex justify-center md:mt-16">
      <Pagination
        basePath={`/blog/`}
        prevUrl={page.url.prev}
        currPage={page.currentPage}
        nextUrl={page.url.next}
        lastPage={page.lastPage}
      />
    </div>
  </section>
</BaseLayout>
