---
import { type InferGetStaticPropsType } from "astro";
import { render } from "astro:content";

import HtmlBlock from "@/components/html-block/HtmlBlock.astro";
import ExternalLink from "@/components/markdown-components/ExternalLink.astro";
import { getAllPosts } from "@/js/blogUtils";
import { getPageLocale } from "@/js/localeUtils";
import BlogLayoutCenter from "@/layouts/BlogLayoutCenter.astro";
import BlogLayoutSidebar from "@/layouts/BlogLayoutSidebar.astro";

export async function getStaticPaths() {
  const posts = await getAllPosts(getPageLocale(import.meta.url));

  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const post = Astro.props as Props;
const { Content, headings } = await render(post);
---

<BlogLayoutSidebar post={post} headings={headings}>
  <Content components={{ a: ExternalLink, HtmlBlock }} />
</BlogLayoutSidebar>
