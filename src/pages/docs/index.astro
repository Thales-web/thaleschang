---
/**
 * Docs index redirects to the first document page.
 */
import { defaultLocale } from "@/config/siteSettings.json";
import { docsRoute, getAllDocs, getTabSections } from "@/js/docsUtils";
import { getLocalizedRoute } from "@/js/translationUtils";

const allDocs = await getAllDocs(defaultLocale);

// Get the first tab's first section's first doc
const tabSections = getTabSections("main", defaultLocale);

if (tabSections.length > 0 && allDocs.length > 0) {
  // Filter docs to "main" tab section
  const mainDocs = allDocs.filter((doc) => doc.data.section === "main");

  // Try to find the index doc of the first section
  const firstSection = tabSections[0];
  const indexDoc = mainDocs.find(
    (doc) => doc.id === firstSection.id || doc.id === `${firstSection.id}/index`,
  );

  if (indexDoc) {
    return Astro.redirect(getLocalizedRoute(defaultLocale, `/${docsRoute}/${indexDoc.id}`));
  }

  // Fallback: sort by order and use first doc
  const sortedDocs = mainDocs
    .filter((doc) => doc.id.startsWith(firstSection.id + "/"))
    .sort((a, b) => {
      const orderA = a.data.sidebar?.order ?? 999;
      const orderB = b.data.sidebar?.order ?? 999;
      return orderA - orderB;
    });

  if (sortedDocs.length > 0) {
    return Astro.redirect(getLocalizedRoute(defaultLocale, `/${docsRoute}/${sortedDocs[0].id}`));
  }
}

// Final fallback: first doc found
if (allDocs.length > 0) {
  return Astro.redirect(getLocalizedRoute(defaultLocale, `/${docsRoute}/${allDocs[0].id}`));
}
