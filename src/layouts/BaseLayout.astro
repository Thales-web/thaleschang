---
import "@/styles/global.css";

import type { ComponentProps } from "astro/types";
import { type CollectionEntry } from "astro:content";

import CookieConsent from "@/components/cookie-consent/CookieConsent.astro";
import Footer from "@/components/footer/Footer.astro";
import Nav from "@/components/nav/Nav.astro";
import GoogleTagManager from "@/components/analytics/GoogleTagManager.astro";
import Breadcrumbs from "@/components/seo/Breadcrumbs.astro";
import siteSettings from "@/config/siteSettings.json";
import { getLocaleFromUrl } from "@/js/localeUtils";
import BaseHead from "@/layouts/BaseHead.astro";

import { type FaqItem } from "@/config/types/configDataTypes";

// heroImage and authorData are defined on blog posts
// authorData could also be defined on the about author page
interface Props extends ComponentProps<typeof Nav> {
  type?: "blog" | "general" | "service" | "person" | "faq";
  title: string;
  description: string;
  image?: ImageMetadata;
  authorsData?: CollectionEntry<"authors">[];
  postFrontmatter?: CollectionEntry<"blog">["data"];
  service?: CollectionEntry<"services">;
  person?: CollectionEntry<"authors">;
  faqItems?: FaqItem[];
  prevUrl?: string;
  nextUrl?: string;
  noindex?: boolean; // you need to opt-in to no indexing, as it hides the page from search engines
}

const {
  type = "general",
  title,
  description,
  image,
  authorsData,
  postFrontmatter,
  service,
  person,
  faqItems,
  prevUrl,
  nextUrl,
  noindex = false,
  ...navProps
} = Astro.props as Props;

const currLocale = getLocaleFromUrl(Astro.url);
---

<!doctype html>
<html lang={currLocale} transition:animate="fade">
  <head>
    <BaseHead
      type={type}
      title={title}
      description={description}
      image={image ? image : undefined}
      authors={authorsData ? authorsData : undefined}
      postFrontmatter={postFrontmatter ? postFrontmatter : undefined}
      service={service}
      person={person}
      faqItems={faqItems}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      noindex={noindex}
    />
  </head>
  <body id="body" class={` ${siteSettings.useAnimations === true ? "use-animations" : ""}`}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground">Skip to content</a>
    <GoogleTagManager position="body" />
    <div id="page" class="">
      <!-- Cookie consent banner (GDPR) -->
      <CookieConsent />

      <Nav {...navProps} />
      <main id="main-content" class="relative min-h-[100lvh] overflow-x-clip">
        <Breadcrumbs />
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Scroll animations -->
    <script>
      import { MOS } from "motion-on-scroll";

      import { siteSettings } from "@/config/siteSettings.json";

      if (siteSettings.useAnimations === true) {
        MOS.init({
          offset: 100,
          duration: 0.8,
          timeUnits: "s",
          distance: 20,
          delay: 0,
          easing: "ease-out-cubic",
          once: true,
          mirror: false,
        });

        document.addEventListener("astro:after-swap", MOS.refreshHard);
      }
    </script>
  </body>
</html>
