---
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute } from "@/js/translationUtils";

/**
 * Compares two paths ensuring they both have trailing slashes for consistency
 */
const comparePathsWithTrailingSlash = (path1: string, path2: string): boolean => {
  const ensureTrailingSlash = (path: string): string => (path.endsWith("/") ? path : `${path}/`);
  return ensureTrailingSlash(path1) === ensureTrailingSlash(path2);
};

interface Props {
  link: string;
  text: string;
  badge?: {
    text: string;
    variant?: "note" | "tip" | "caution" | "danger" | "info";
  };
}

const { link, text, badge } = Astro.props;

const currLocale = getLocaleFromUrl(Astro.url);
let actualLink = getLocalizedRoute(currLocale, link);
const currentPath = comparePathsWithTrailingSlash(Astro.url.pathname, actualLink);
---

<li>
  <a
    href={actualLink}
    class:list={[
      "docs-nav__link--sidebar docs-primary-focus block text-base md:text-sm",
      {
        "text-foreground font-medium": currentPath,
      },
    ]}
  >
    <div class="flex items-center gap-2">
      <span>{text}</span>
      {badge && (
        <span
          class:list={[
            "inline-block rounded-full px-1.5 py-0.5 text-[10px] font-semibold leading-none",
            {
              "bg-info text-info-foreground": badge.variant === "info" || badge.variant === "note" || !badge.variant,
              "bg-success text-success-foreground": badge.variant === "tip",
              "bg-warning text-warning-foreground": badge.variant === "caution",
              "bg-error text-error-foreground": badge.variant === "danger",
            },
          ]}
        >
          {badge.text}
        </span>
      )}
    </div>
  </a>
</li>
